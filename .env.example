# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional — model override (default: claude-sonnet-4-6)
HARRY_MODEL=claude-sonnet-4-6

# Optional — wake word (Harry only responds when it hears this)
HARRY_WAKE_WORD=harry

# Optional — OpenWeather key for weather agent
OPENWEATHER_API_KEY=

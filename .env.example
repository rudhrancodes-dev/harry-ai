# ─── Brain backend ────────────────────────────────────────────────────────
# Pick ONE of:  claude-code | openrouter | openai-compat | off
HARRY_BRAIN=claude-code

# claude-code backend  →  uses your Claude Pro / Max plan via the `claude` CLI.
# Requires Claude Code to be installed and logged in (claude /login).
# No API key needed.

# openrouter backend  →  one key, hundreds of models (DeepSeek, GPT, Claude, ...)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324

# openai-compat backend  →  any OpenAI-compatible endpoint
# Works with: opencode, Ollama, LM Studio, vLLM, DeepSeek direct, Groq, Together.
OPENCODE_API_KEY=
OPENCODE_BASE_URL=http://localhost:11434/v1
OPENCODE_MODEL=deepseek-chat

# ─── Personalisation ──────────────────────────────────────────────────────
HARRY_USER_NAME=Rudhran
HARRY_ADDRESS=sir
HARRY_PERSONA_EXTRA=

# ─── Voice & wake word ────────────────────────────────────────────────────
HARRY_WAKE_WORD=harry
HARRY_STT_ENERGY=300
HARRY_STT_PAUSE=0.8
HARRY_MAX_CLARIFY=2

# ─── Optional integrations ────────────────────────────────────────────────
OPENWEATHER_API_KEY=
